# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# E2E tests use local values by default. Set TEST_PRODUCTION=true to use the
# production E2E values below.
TEST_PRODUCTION=false

E2E_LOCAL_BASE_URL=http://localhost:3000
E2E_LOCAL_SUPABASE_URL=http://127.0.0.1:54321
E2E_LOCAL_SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
E2E_LOCAL_USER_EMAIL=local-test-user@example.com
E2E_LOCAL_USER_PASSWORD=local-test-password
E2E_LOCAL_SECOND_USER_EMAIL=local-second-test-user@example.com
E2E_LOCAL_SECOND_USER_PASSWORD=local-second-test-password
E2E_LOCAL_USER_ID=
E2E_LOCAL_SECOND_USER_ID=

E2E_BASE_URL=https://your-production-or-preview-url.example
E2E_SUPABASE_URL=https://your-project-ref.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
E2E_USER_EMAIL=production-test-user@example.com
E2E_USER_PASSWORD=production-test-password
E2E_SECOND_USER_EMAIL=production-second-test-user@example.com
E2E_SECOND_USER_PASSWORD=production-second-test-password
E2E_USER_ID=
E2E_SECOND_USER_ID=
E2E_ALLOW_PRODUCTION_WRITES=false
